#include <stdio.h>
#include <string.h>

int main() {
    char codigo[20];
    char nombre[50];
    char inicial;
    int edad;
    int opcion;

    do {
        printf("\n--- Programa de CRISTOPHER ---\n");
        printf("1. Ingresar datos\n");
        printf("2. Salir\n");
        printf("Seleccione una opcion: ");
        scanf("%d", &opcion);

        if (opcion == 1) {

            printf("Ingrese su codigo: ");
            scanf("%s", codigo);

            if (strncmp(codigo, "20261005", 8) == 0) {

                printf("Ingrese su nombre: ");
                scanf("%s", nombre);

                printf("Ingrese la inicial de su apellido: ");
                scanf(" %c", &inicial);

                // 🔹 Convertir a mayúscula con ternario
                inicial = (inicial >= 'a' && inicial <= 'z') ? inicial - 32 : inicial;

                printf("Ingrese su edad: ");
                scanf("%d", &edad);

                printf("\nResultado:\n");
                printf("%s %c - %s - %d anos\n", nombre, inicial, codigo, edad);

            } else {
    printf("Usted no pertenece a esta clase.\n");
            }

        } else if (opcion == 2) {
            printf("Saliendo del programa...\n");
        } else {
            printf("Opcion no valida.\n");
        }

    } while (opcion != 2);

    return 0;
}

