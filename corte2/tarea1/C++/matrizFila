#include <iostream>
using namespace std;

/* Prototipos */
void leerMatriz(int m[][3], int filas);
int sumarFila(int m[][3], int fila);
void mostrarSumasPorFila(int m[][3], int filas);

int main() {
    /* Declaración de variables */
    int m[3][3];

    /* Llamadas a funciones */
    leerMatriz(m, 3);

    cout << "\nMatriz:\n";
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            cout << m[i][j] << " ";
        }
        cout << endl;
    }

    mostrarSumasPorFila(m, 3);

    return 0;
}

/* Definición de funciones */

void leerMatriz(int m[][3], int filas) {
    for (int i = 0; i < filas; i++) {
        for (int j = 0; j < 3; j++) {
            cout << "Digite m[" << i << "][" << j << "]: ";
            cin >> m[i][j];
        }
    }
}

int sumarFila(int m[][3], int fila) {
    int suma = 0;
    for (int j = 0; j < 3; j++) {
        suma += m[fila][j];
    }
    return suma;
}

void mostrarSumasPorFila(int m[][3], int filas) {
    for (int i = 0; i < filas; i++) {
        cout << "Suma fila " << i << ": " << sumarFila(m, i) << endl;
    }
}
